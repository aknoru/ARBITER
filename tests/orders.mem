// Binary-encoded orders for Verilog testbench -- use $readmemh
// 128-bit packed word per order, 32 hex digits per line
// [127:96]=timestamp [95:64]=order_id [63]=side(1=BUY) [62:48]=rsvd [47:32]=price [31:16]=qty [15:0]=rsvd
//
// id:    101=65 102=66 103=67 104=68 105=69 106=6A 107=6B 108=6C 109=6D 110=6E 111=6F
// price: 98=62  99=63 100=64 101=65 102=66 103=67
// BUY side field = 8000, SELL = 0000
//
// Batch 1
000000010000006580000064000A0000
00000002000000660000006300050000
00000003000000678000006500030000
00000004000000680000006400080000
00000005000000698000006200060000
000000060000006A0000006600040000
000000070000006B8000006700070000
000000080000006C0000006400020000
// Batch 2
000000090000006D8000006600040000
0000000A0000006E0000006200030000
0000000B0000006F8000006300020000
